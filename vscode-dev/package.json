{
  "name": "mercurio-language-workbench",
  "displayName": "Mercurio Language Workbench",
  "description": "SysML v2 and KerML language support powered by Mercurio.",
  "repository": { "type": "git", "url": "https://github.com/mercurio-labs/mercurio-host-adapters.git" },
  "files": ["dist/**", "server/**", "README.md", "LICENSE", "grammars/**"],
  "publisher": "mercurio",
  "version": "0.1.0",
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:sysml", "onLanguage:kerml", "onView:mercurio.containment"],
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      { "id": "sysml", "extensions": [".sysml"], "aliases": ["SysML v2"] },
      { "id": "kerml", "extensions": [".kerml"], "aliases": ["KerML"] }
    ],
    "grammars": [
      { "language": "sysml", "scopeName": "source.mercurio", "path": "./grammars/mercurio.tmLanguage.json" },
      { "language": "kerml", "scopeName": "source.mercurio", "path": "./grammars/mercurio.tmLanguage.json" }
    ],
    "commands": [
      { "command": "mercurio.refreshContainment", "title": "Mercurio: Refresh Containment" },
      { "command": "mercurio.openContainmentElement", "title": "Mercurio: Open Containment Element" }
    ],
    "views": {
      "explorer": [
        { "id": "mercurio.containment", "name": "Mercurio Containment" }
      ]
    },
    "configuration": {
      "title": "Mercurio Language Workbench",
      "properties": {
        "mercurio.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Optional override for the Mercurio LSP host. By default the extension uses its bundled server, then checks an installed app or PATH."
        }
      }
    }
  },
  "scripts": {
    "generate:grammar": "cargo run --manifest-path ../Cargo.toml -p mercurio-lsp-host --bin generate_vscode_grammar -- grammars/mercurio.tmLanguage.json",
    "check:grammar": "npm run generate:grammar && git diff --exit-code -- grammars/mercurio.tmLanguage.json",
    "build:extension": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "stage:server": "node scripts/stage-server.js",
    "test:containment": "node scripts/smoke-containment.js",
    "package": "npm run build:extension && npm run stage:server && node scripts/package-vsix.js"
  },
  "dependencies": { "vscode-languageclient": "^9.0.1" },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0"
  }
}